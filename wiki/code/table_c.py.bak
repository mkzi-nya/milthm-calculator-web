from __future__ import annotations

import json
from pathlib import Path
from typing import Any


SCRIPT_DIR = Path(__file__).resolve().parent
INPUT_JSON ='../../resources/resources.json'
OUTPUT_HTML = SCRIPT_DIR.parent / 'table_c.html'

DIFFICULTY_ORDER = ['Drizzle', 'Sprinkle', 'Cloudburst', 'Clear', 'Special']
DIFFICULTY_SHORT = {
    'Drizzle': 'DZ',
    'Sprinkle': 'SK',
    'Cloudburst': 'CB',
    'Clear': 'CL',
    'Special': 'SP',
}


HTML_TEMPLATE = '''<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>定数表</title>
  <style>
    :root {
      --bg: #0d1117;
      --panel: #161b22;
      --panel-2: #1f2630;
      --text: #e6edf3;
      --muted: #9da7b3;
      --line: #30363d;
      --accent: #58a6ff;
      --accent-2: #79c0ff;
      --danger: #f85149;
      --shadow: 0 12px 36px rgba(0, 0, 0, 0.35);
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      padding: 0;
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "PingFang SC",
        "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
    }

    body {
      padding: 24px;
    }

    .container {
      width: min(1200px, 100%);
      margin: 0 auto;
    }

    .header {
      margin-bottom: 20px;
    }

    .title {
      margin: 0 0 8px;
      font-size: 32px;
      line-height: 1.2;
    }

    .subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.6;
    }

    .toolbar {
      display: grid;
      grid-template-columns: minmax(0, 1fr) 150px auto;
      gap: 12px;
      margin: 20px 0;
    }

    .input,
    .select,
    .button {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--panel);
      color: var(--text);
      padding: 10px 12px;
      font-size: 14px;
    }

    .button {
      cursor: pointer;
      transition: border-color 0.16s ease, background 0.16s ease;
    }

    .button:hover,
    .input:focus,
    .select:focus {
      outline: none;
      border-color: var(--accent);
    }

    .stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 14px;
      color: var(--muted);
      font-size: 13px;
    }

    .chip {
      padding: 6px 10px;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 999px;
    }

    .table-wrap {
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--panel);
      box-shadow: var(--shadow);
    }

    table {
      width: 100%;
      border-collapse: collapse;
    }

    thead {
      background: #11161d;
    }

    th,
    td {
      padding: 12px 14px;
      border-bottom: 1px solid var(--line);
      text-align: left;
      vertical-align: top;
      font-size: 14px;
    }

    th {
      color: var(--muted);
      font-weight: 600;
      white-space: nowrap;
    }

    tbody tr:hover {
      background: rgba(88, 166, 255, 0.06);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    .constant {
      width: 92px;
      white-space: nowrap;
      font-variant-numeric: tabular-nums;
    }

    .diff {
      width: 72px;
      white-space: nowrap;
      color: var(--accent-2);
      font-weight: 600;
    }

    .song-button {
      appearance: none;
      border: none;
      background: transparent;
      color: inherit;
      cursor: pointer;
      padding: 0;
      text-align: left;
      font: inherit;
    }

    .song-button:hover {
      color: var(--accent-2);
    }

    .song-main {
      display: block;
      font-weight: 600;
      line-height: 1.5;
    }

    .song-sub {
      display: block;
      color: var(--muted);
      font-size: 12px;
      line-height: 1.5;
      margin-top: 2px;
    }

    .muted {
      color: var(--muted);
    }

    .empty {
      padding: 28px 16px;
      text-align: center;
      color: var(--muted);
      background: var(--panel);
      border-top: 1px solid var(--line);
    }

    .overlay {
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.56);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
      z-index: 1000;
    }

    .overlay.open {
      display: flex;
    }

    .modal {
      width: min(860px, 100%);
      max-height: min(90vh, 900px);
      overflow: auto;
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: 16px;
      box-shadow: var(--shadow);
    }

    .modal-header {
      position: sticky;
      top: 0;
      z-index: 1;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      padding: 18px 20px;
      background: rgba(22, 27, 34, 0.96);
      border-bottom: 1px solid var(--line);
      backdrop-filter: blur(8px);
    }

    .modal-title {
      margin: 0;
      font-size: 24px;
      line-height: 1.3;
    }

    .modal-subtitle {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.5;
    }

    .close-btn {
      width: 38px;
      height: 38px;
      border: 1px solid var(--line);
      border-radius: 10px;
      background: var(--panel-2);
      color: var(--text);
      cursor: pointer;
      font-size: 20px;
      line-height: 1;
    }

    .modal-body {
      padding: 20px;
    }

    .grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .card {
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--panel-2);
    }

    .card h3 {
      margin: 0 0 10px;
      font-size: 14px;
      color: var(--muted);
    }

    .kv {
      display: grid;
      grid-template-columns: 110px minmax(0, 1fr);
      gap: 8px 12px;
      margin: 0;
    }

    .kv dt {
      color: var(--muted);
    }

    .kv dd {
      margin: 0;
      word-break: break-word;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 6px;
    }

    .tag {
      padding: 4px 8px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: #11161d;
      color: #c9d1d9;
      font-size: 12px;
    }

    code.inline {
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      font-size: 12px;
      background: #11161d;
      border: 1px solid var(--line);
      border-radius: 6px;
      padding: 2px 6px;
    }

    @media (max-width: 820px) {
      body {
        padding: 16px;
      }

      .toolbar {
        grid-template-columns: 1fr;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      th:nth-child(4), td:nth-child(4),
      th:nth-child(5), td:nth-child(5) {
        display: none;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <header class="header">
      <h1 class="title">定数表</h1>
      <p class="subtitle">
        本页面由单个 <code class="inline">resources.json</code> 生成；不依赖其他输入文件。
      </p>
    </header>

    <section class="toolbar">
      <input id="searchInput" class="input" type="search" placeholder="搜索曲名 / 艺术家 / 谱师 / chartid">
      <select id="difficultyFilter" class="select">
        <option value="">全部难度</option>
        <option value="DZ">DZ</option>
        <option value="SK">SK</option>
        <option value="CB">CB</option>
        <option value="CL">CL</option>
        <option value="SP">SP</option>
      </select>
      <button id="resetButton" class="button" type="button">重置筛选</button>
    </section>

    <div class="stats">
      <span class="chip" id="totalCount"></span>
      <span class="chip" id="visibleCount"></span>
      <span class="chip">排序：定数降序</span>
    </div>

    <section class="table-wrap">
      <table>
        <thead>
          <tr>
            <th class="constant">定数</th>
            <th>曲目</th>
            <th class="diff">难度</th>
            <th>艺术家</th>
            <th>谱师</th>
          </tr>
        </thead>
        <tbody id="tableBody"></tbody>
      </table>
      <div id="emptyState" class="empty" hidden>没有匹配结果。</div>
    </section>
  </div>

  <div id="overlay" class="overlay" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal-header">
        <div>
          <h2 id="modalTitle" class="modal-title"></h2>
          <p id="modalSubtitle" class="modal-subtitle"></p>
        </div>
        <button id="closeButton" class="close-btn" type="button" aria-label="关闭">×</button>
      </div>
      <div id="modalBody" class="modal-body"></div>
    </div>
  </div>

  <script id="chart-data" type="application/json">__CHARTS_JSON__</script>
  <script>
    const CHARTS = JSON.parse(document.getElementById('chart-data').textContent);
    const tableBody = document.getElementById('tableBody');
    const emptyState = document.getElementById('emptyState');
    const searchInput = document.getElementById('searchInput');
    const difficultyFilter = document.getElementById('difficultyFilter');
    const resetButton = document.getElementById('resetButton');
    const totalCount = document.getElementById('totalCount');
    const visibleCount = document.getElementById('visibleCount');
    const overlay = document.getElementById('overlay');
    const closeButton = document.getElementById('closeButton');
    const modalTitle = document.getElementById('modalTitle');
    const modalSubtitle = document.getElementById('modalSubtitle');
    const modalBody = document.getElementById('modalBody');

    totalCount.textContent = `总谱面数：${CHARTS.length}`;

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatValue(value, blankWhenNegativeOne = false) {
      if (value === null || value === undefined || value === '') return '';
      const number = Number(value);
      if (!Number.isNaN(number)) {
        if (blankWhenNegativeOne && number === -1) return '';
        return Number.isInteger(number) ? String(number) : String(number);
      }
      return String(value);
    }

    function tagsHtml(tags) {
      if (!Array.isArray(tags) || tags.length === 0) return '<span class="muted">无</span>';
      return `<div class="tags">${tags.map(tag => `<span class="tag">${escapeHtml(tag)}</span>`).join('')}</div>`;
    }

    function renderTable(rows) {
      tableBody.innerHTML = rows.map((chart, index) => {
        const artist = chart.artist || '';
        const charter = chart.charter || '';
        const titleLine = escapeHtml(chart.title);
        const subParts = [];
        if (chart.latinTitle && chart.latinTitle !== chart.title) subParts.push(chart.latinTitle);
        if (chart.chartid) subParts.push(`chartid: ${chart.chartid}`);
        const subLine = subParts.length > 0
          ? `<span class="song-sub">${escapeHtml(subParts.join(' · '))}</span>`
          : '';

        return `
          <tr>
            <td class="constant">${escapeHtml(formatValue(chart.constant, true))}</td>
            <td>
              <button class="song-button" type="button" data-index="${index}">
                <span class="song-main">${titleLine}</span>
                ${subLine}
              </button>
            </td>
            <td class="diff">${escapeHtml(chart.difficultyShort)}</td>
            <td>${escapeHtml(artist)}</td>
            <td>${escapeHtml(charter)}</td>
          </tr>
        `;
      }).join('');

      emptyState.hidden = rows.length !== 0;
      visibleCount.textContent = `当前显示：${rows.length}`;

      tableBody.querySelectorAll('.song-button').forEach(button => {
        button.addEventListener('click', () => {
          const index = Number(button.dataset.index);
          openModal(rows[index]);
        });
      });
    }

    function openModal(chart) {
      modalTitle.textContent = chart.title;
      modalSubtitle.textContent = `${chart.difficultyShort} · 定数 ${formatValue(chart.constant, true) || '空'} · 艺术家 ${chart.artist || '未知'}`;

      const bpmText = Array.isArray(chart.bpmInfo) && chart.bpmInfo.length > 0
        ? chart.bpmInfo.map(item => `${item.start}:${item.bpm}`).join(' | ')
        : '';
      const notesText = [
        ['Tap', chart.tap],
        ['Hold', chart.hold],
        ['Drag', chart.drag],
        ['Fracture', chart.fracture],
        ['EX', chart.ex],
        ['Combo', chart.combo],
      ].map(([k, v]) => `${k}=${formatValue(v) || 0}`).join(' · ');

      modalBody.innerHTML = `
        <div class="grid">
          <section class="card">
            <h3>基础信息</h3>
            <dl class="kv">
              <dt>曲名</dt><dd>${escapeHtml(chart.title || '')}</dd>
              <dt>拉丁标题</dt><dd>${escapeHtml(chart.latinTitle || '') || '<span class="muted">无</span>'}</dd>
              <dt>难度</dt><dd>${escapeHtml(chart.difficulty || '')} (${escapeHtml(chart.difficultyShort || '')})</dd>
              <dt>定数</dt><dd>${escapeHtml(formatValue(chart.constant, true)) || '<span class="muted">空</span>'}</dd>
              <dt>chartid</dt><dd><code class="inline">${escapeHtml(chart.chartid || '')}</code></dd>
              <dt>songid</dt><dd><code class="inline">${escapeHtml(chart.songid || '')}</code></dd>
            </dl>
          </section>

          <section class="card">
            <h3>制作信息</h3>
            <dl class="kv">
              <dt>艺术家</dt><dd>${escapeHtml(chart.artist || '')}</dd>
              <dt>谱师</dt><dd>${escapeHtml(chart.charter || '')}</dd>
              <dt>画师</dt><dd>${escapeHtml(chart.illustrators || '')}</dd>
              <dt>标题文化</dt><dd>${escapeHtml(chart.titleCulture || '')}</dd>
              <dt>歌曲隐藏</dt><dd>${escapeHtml(chart.songHidden || '')}</dd>
              <dt>谱面隐藏</dt><dd>${escapeHtml(chart.chartHidden || '')}</dd>
            </dl>
          </section>

          <section class="card">
            <h3>谱面参数</h3>
            <dl class="kv">
              <dt>difficultyValue</dt><dd>${escapeHtml(formatValue(chart.difficultyValue))}</dd>
              <dt>difficultyValuev2</dt><dd>${escapeHtml(formatValue(chart.constant, true)) || '<span class="muted">空</span>'}</dd>
              <dt>AFDValue</dt><dd>${escapeHtml(formatValue(chart.afdValue))}</dd>
              <dt>raderValue</dt><dd>${escapeHtml(chart.raderValue || '') || '<span class="muted">无</span>'}</dd>
              <dt>BPM 片段</dt><dd>${escapeHtml(bpmText) || '<span class="muted">无</span>'}</dd>
              <dt>谱面时长</dt><dd>${escapeHtml(chart.duration || '')}</dd>
            </dl>
          </section>

          <section class="card">
            <h3>物量统计</h3>
            <dl class="kv">
              <dt>基础统计</dt><dd>${escapeHtml(notesText)}</dd>
              <dt>Fake Tap</dt><dd>${escapeHtml(formatValue(chart.fakeTap))}</dd>
              <dt>Fake Hold</dt><dd>${escapeHtml(formatValue(chart.fakeHold))}</dd>
              <dt>Fake Drag</dt><dd>${escapeHtml(formatValue(chart.fakeDrag))}</dd>
              <dt>Fake Fracture</dt><dd>${escapeHtml(formatValue(chart.fakeFracture))}</dd>
              <dt>Fake Combo</dt><dd>${escapeHtml(formatValue(chart.fakeCombo))}</dd>
              <dt>有判数</dt><dd>${escapeHtml(formatValue(chart.judgedNotes))}</dd>
              <dt>单note</dt><dd>${escapeHtml(formatValue(chart.singleNote))}</dd>
              <dt>有判占比</dt><dd>${escapeHtml(formatValue(chart.judgedRatio))}</dd>
            </dl>
          </section>
        </div>

        <section class="card" style="margin-top: 14px;">
          <h3>标签</h3>
          ${tagsHtml(chart.tags)}
        </section>
      `;

      overlay.classList.add('open');
      overlay.setAttribute('aria-hidden', 'false');
    }

    function closeModal() {
      overlay.classList.remove('open');
      overlay.setAttribute('aria-hidden', 'true');
    }

    function getFilteredCharts() {
      const keyword = searchInput.value.trim().toLowerCase();
      const difficulty = difficultyFilter.value;

      return CHARTS.filter(chart => {
        if (difficulty && chart.difficultyShort !== difficulty) return false;
        if (!keyword) return true;

        const haystack = [
          chart.title,
          chart.latinTitle,
          chart.artist,
          chart.charter,
          chart.chartid,
          chart.difficulty,
          chart.difficultyShort,
          ...(Array.isArray(chart.tags) ? chart.tags : []),
        ]
          .filter(Boolean)
          .join('\n')
          .toLowerCase();

        return haystack.includes(keyword);
      });
    }

    function refresh() {
      renderTable(getFilteredCharts());
    }

    searchInput.addEventListener('input', refresh);
    difficultyFilter.addEventListener('change', refresh);
    resetButton.addEventListener('click', () => {
      searchInput.value = '';
      difficultyFilter.value = '';
      refresh();
    });

    closeButton.addEventListener('click', closeModal);
    overlay.addEventListener('click', (event) => {
      if (event.target === overlay) closeModal();
    });
    window.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeModal();
    });

    refresh();
  </script>
</body>
</html>
'''


def to_float(value: Any) -> float | None:
    if value is None:
        return None
    if isinstance(value, (int, float)):
        return float(value)
    text = str(value).strip()
    if not text:
        return None
    try:
        return float(text)
    except ValueError:
        return None


def compact_join(values: list[Any] | None) -> str:
    if not values:
        return ''
    parts = [str(v).strip() for v in values if str(v).strip()]
    return ', '.join(parts)


def build_chart_list(resources: dict[str, Any]) -> list[dict[str, Any]]:
    charts: list[dict[str, Any]] = []

    for title, song in resources.items():
        difficulties = song.get('difficulty', {})
        for difficulty_name in DIFFICULTY_ORDER:
            diff = difficulties.get(difficulty_name)
            if not isinstance(diff, dict):
                continue

            constant = to_float(diff.get('difficultyValuev2'))
            if constant is None:
                constant = to_float(diff.get('difficultyValue'))
            if constant is None:
                continue

            charts.append({
                'title': title,
                'latinTitle': song.get('latinTitle', ''),
                'titleCulture': song.get('titleCulture', ''),
                'artist': song.get('artist', ''),
                'artists': compact_join(song.get('artistsList')),
                'illustrators': compact_join(song.get('illustratorsList') or song.get('illustrator')),
                'songid': song.get('songid', ''),
                'songHidden': song.get('歌曲解锁前隐藏', ''),
                'difficulty': difficulty_name,
                'difficultyShort': DIFFICULTY_SHORT[difficulty_name],
                'chartid': diff.get('chartid', ''),
                'difficultyValue': diff.get('difficultyValue', ''),
                'constant': constant,
                'afdValue': diff.get('AFDValue', ''),
                'raderValue': compact_join(diff.get('raderValue')),
                'charter': diff.get('charter', ''),
                'bpmInfo': diff.get('bpmInfo', []),
                'tap': diff.get('tap', 0),
                'hold': diff.get('hold', 0),
                'drag': diff.get('drag', 0),
                'fracture': diff.get('fracture', 0),
                'ex': diff.get('ex', 0),
                'combo': diff.get('combo', 0),
                'fakeTap': diff.get('fake_tap', 0),
                'fakeHold': diff.get('fake_hold', 0),
                'fakeDrag': diff.get('fake_drag', 0),
                'fakeFracture': diff.get('fake_fracture', 0),
                'fakeCombo': diff.get('fake_combo', 0),
                'judgedNotes': diff.get('有判数', ''),
                'singleNote': diff.get('单note', ''),
                'judgedRatio': diff.get('有判占比', ''),
                'duration': diff.get('谱面时长', ''),
                'chartHidden': diff.get('谱面解锁前隐藏', ''),
                'tags': diff.get('tags', []) or song.get('tags', []),
            })

    charts.sort(key=lambda item: (-item['constant'], item['title'], DIFFICULTY_ORDER.index(item['difficulty'])))
    return charts


def render_html(charts: list[dict[str, Any]]) -> str:
    charts_json = json.dumps(charts, ensure_ascii=False, separators=(',', ':')).replace('</', '<\\/')
    return HTML_TEMPLATE.replace('__CHARTS_JSON__', charts_json)


def main() -> None:
    with INPUT_JSON.open('r', encoding='utf-8') as f:
        resources = json.load(f)

    if not isinstance(resources, dict):
        raise ValueError('resources.json 的顶层必须是对象（曲名 -> 数据）。')

    charts = build_chart_list(resources)
    html = render_html(charts)

    OUTPUT_HTML.write_text(html, encoding='utf-8')
    print(f'成功生成 {OUTPUT_HTML}')
    print(f'共写入 {len(charts)} 个谱面，数据源：{INPUT_JSON}')


if __name__ == '__main__':
    main()
